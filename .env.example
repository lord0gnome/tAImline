# --- App ---
PORT=4321
# Public base URL of the app (used for OAuth callbacks, OG tags)
PUBLIC_BASE_URL=http://localhost:4321

# --- Database ---
# Path to the SQLite file (a libSQL/Turso URL later; Postgres URL if dialect is swapped)
DATABASE_PATH=./data/taimline.db

# --- Sessions ---
# Long random string used to derive/sign session tokens
SESSION_SECRET=change-me-to-a-long-random-string

# --- Admins ---
# Comma/space-separated email allowlist. A signed-in user whose email is listed
# is an admin and can configure OIDC sign-in at /app/settings. Kept in env (not
# the DB) so it survives DB resets and you can't lock yourself out.
ADMIN_EMAILS=

# --- OIDC (generic, admin-configured at runtime) ---
# The generic OpenID Connect provider (issuer / client id / secret / scopes) is
# configured in-app under Settings → "OIDC sign-in (admin)" and stored in the
# DB, NOT here. Nothing to set in env for OIDC.

# --- Dev login (LOCAL ONLY) ---
# Set to 1 to enable the "Dev login" shortcut at /auth/dev (signs in as a local
# dev user, no OAuth). NEVER set this in the cluster / production.
DEV_LOGIN=0

# --- OAuth: GitHub (M1) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth: Google (M1, later) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Object storage / S3-compatible (M3) ---
# AWS S3: leave S3_ENDPOINT empty and set S3_REGION to the bucket's region
#         (e.g. eu-west-3) — the URL is derived as <bucket>.s3.<region>.amazonaws.com.
# R2/MinIO/other: set S3_ENDPOINT (e.g. https://<acct>.r2.cloudflarestorage.com)
#         and S3_REGION=auto; path-style addressing is used.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
