---
import "~/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  /** Full-bleed, full-height layout (no centered container, no footer). */
  fullBleed?: boolean;
}

const {
  title = "tAImline",
  description = "A zoomable timeline of your life, organized into eras.",
  ogImage,
  ogType = "website",
  noindex = false,
  fullBleed = false,
} = Astro.props;

const user = Astro.locals.user;
const base = import.meta.env.PUBLIC_BASE_URL ?? "";
const canonical = base ? new URL(Astro.url.pathname, base).toString() : Astro.url.pathname;
const absImage = ogImage && base && ogImage.startsWith("/") ? `${base}${ogImage}` : ogImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {absImage && <meta property="og:image" content={absImage} />}
    <meta name="twitter:card" content={absImage ? "summary_large_image" : "summary"} />
    <title>{title}</title>
    <script is:inline>
      // Apply the saved theme before paint to avoid a flash.
      try {
        const t = localStorage.getItem("taimline-theme");
        if (t === "dark" || t === "light") document.documentElement.dataset.theme = t;
      } catch (_) {}
    </script>
  </head>
  <body class={fullBleed ? "body--full" : undefined}>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">t<b>AI</b>mline</a>
        <nav style="display: flex; align-items: center; gap: 0.75rem;">
          <button id="theme-toggle" class="btn" type="button" aria-label="Toggle theme" title="Theme">🖥</button>
          {
            user ? (
              <>
                <a class="btn" href="/app">My timeline</a>
                <a class="btn" href="/app/settings">Settings</a>
                <span class="muted" style="font-size: 0.9rem;">{user.displayName}</span>
                <form method="POST" action="/logout" style="margin: 0;">
                  <button class="btn" type="submit">Sign out</button>
                </form>
              </>
            ) : (
              <a class="btn btn--primary" href="/login">
                Sign in
              </a>
            )
          }
        </nav>
      </div>
    </header>

    <main class={fullBleed ? "main--full" : "container"}>
      <slot />
    </main>

    {
      !fullBleed && (
        <footer class="site-footer">
          <div class="container">tAImline — chapters of a life, on one timeline.</div>
        </footer>
      )
    }
    <script is:inline>
      // Theme toggle: cycles system → light → dark, persisted in localStorage.
      (() => {
        const btn = document.getElementById("theme-toggle");
        if (!btn) return;
        const order = ["system", "light", "dark"];
        const icon = { system: "🖥", light: "☀️", dark: "🌙" };
        const cur = () => {
          let t;
          try { t = localStorage.getItem("taimline-theme"); } catch (_) {}
          return order.includes(t) ? t : "system";
        };
        const apply = (t) => {
          try {
            if (t === "system") {
              delete document.documentElement.dataset.theme;
              localStorage.removeItem("taimline-theme");
            } else {
              document.documentElement.dataset.theme = t;
              localStorage.setItem("taimline-theme", t);
            }
          } catch (_) {}
          btn.textContent = icon[t];
          btn.title = "Theme: " + t;
        };
        apply(cur());
        btn.addEventListener("click", () => apply(order[(order.indexOf(cur()) + 1) % order.length]));
      })();
    </script>
  </body>
</html>
