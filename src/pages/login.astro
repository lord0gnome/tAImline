---
import Base from "~/layouts/Base.astro";
---

<Base title="Sign in — tAImline">
  <section style="padding-block: 4rem; max-width: 24rem; margin-inline: auto;">
    <div class="card">
      <h1 style="font-size: 1.5rem;">Sign in</h1>
      <p class="muted">
        OAuth sign-in (GitHub, then Google) lands in the next milestone.
      </p>
      <button class="btn btn--primary" style="width: 100%;" disabled>
        Continue with GitHub
      </button>
    </div>
  </section>
</Base>
