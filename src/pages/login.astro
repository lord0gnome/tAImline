---
import Base from "~/layouts/Base.astro";
import { devLoginEnabled } from "~/auth/dev.ts";

// Already signed in? Go straight to the app.
if (Astro.locals.user) return Astro.redirect("/app");

const devLogin = devLoginEnabled();
---

<Base title="Sign in — tAImline">
  <section style="padding-block: 4rem; max-width: 24rem; margin-inline: auto;">
    <div class="card">
      <h1 style="font-size: 1.5rem;">Sign in</h1>
      <p class="muted">Sign in to build and share your timeline.</p>
      <a class="btn btn--primary" style="width: 100%; justify-content: center;" href="/auth/google">
        Continue with Google
      </a>
      <p class="muted" style="font-size: 0.85rem; margin-bottom: 0;">
        GitHub sign-in is coming next.
      </p>
      {
        devLogin && (
          <a
            class="btn"
            style="width: 100%; justify-content: center; margin-top: 0.75rem;"
            href="/auth/dev"
          >
            Dev login (local testing)
          </a>
        )
      }
    </div>
  </section>
</Base>
