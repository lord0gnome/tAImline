---
import Base from "~/layouts/Base.astro";
import Timeline from "~/timeline/Timeline.tsx";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");
---

<Base title="My timeline — tAImline">
  <section style="padding-block: 1.5rem;">
    <h1 style="font-size: 1.75rem;">My timeline</h1>
    <p class="muted">
      Signed in as <strong>{user.displayName}</strong> ({"@"}{user.handle}).
      Add eras — the overlapping chapters of your life — and they stack into
      lanes automatically.
    </p>
    <Timeline client:only="solid-js" birthDate={user.birthDate} />
  </section>
</Base>
