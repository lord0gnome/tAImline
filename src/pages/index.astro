---
import Base from "~/layouts/Base.astro";
import { listPublicProfiles } from "~/lib/publicView.ts";

const profiles = listPublicProfiles();
---

<Base>
  <section style="padding-block: 4rem; max-width: 42rem;">
    <h1 style="font-size: clamp(2rem, 5vw, 3.25rem);">
      Your life, as a timeline of <span style="color: var(--accent)">eras</span>.
    </h1>
    <p class="muted" style="font-size: 1.15rem;">
      tAImline lays your life out left to right — zoomable from decades down to
      days — and organizes it into overlapping <strong>eras</strong>: the
      chapters where something particular was happening. Add writing, photos and
      links to each era, then keep them private, share with a few people, or
      publish.
    </p>
    <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
      <a class="btn btn--primary" href="/login">Start your timeline</a>
      <a class="btn" href="/login">See an example</a>
    </div>
  </section>

  <section style="padding-bottom: 4rem;">
    <h2>Explore public timelines</h2>
    {
      profiles.length === 0 ? (
        <p class="muted">No public timelines yet — be the first to share yours.</p>
      ) : (
        <div class="explore">
          {profiles.map((p) => (
            <a class="card explore__card" href={`/u/${p.handle}`}>
              {p.avatarUrl && <img src={p.avatarUrl} alt="" />}
              <div>
                <strong>{p.displayName}</strong>
                <div class="muted" style="font-size:0.85rem;">@{p.handle}</div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Base>
